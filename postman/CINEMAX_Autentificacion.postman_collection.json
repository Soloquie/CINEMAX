  "item": [
    {
      "name": "Login válido user 1",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let responseJson = {};\r",
              "try {\r",
              "    responseJson = pm.response.json();\r",
              "} catch (e) {\r",
              "    responseJson = {};\r",
              "}\r",
              "\r",
              "// 1. Validar status code\r",
              "pm.test(\"Login válido user 1 - el status code debe ser 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// 2. Validar que la respuesta sea JSON\r",
              "pm.test(\"Login válido user 1 - la respuesta debe ser JSON\", function () {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "});\r",
              "\r",
              "// 3. Validar accessToken\r",
              "pm.test(\"Login válido user 1 - debe retornar accessToken\", function () {\r",
              "    pm.expect(responseJson.accessToken).to.exist;\r",
              "    pm.expect(responseJson.accessToken).to.be.a(\"string\");\r",
              "    pm.expect(responseJson.accessToken.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "// 4. Validar refreshToken\r",
              "pm.test(\"Login válido user 1 - debe retornar refreshToken\", function () {\r",
              "    pm.expect(responseJson.refreshToken).to.exist;\r",
              "    pm.expect(responseJson.refreshToken).to.be.a(\"string\");\r",
              "    pm.expect(responseJson.refreshToken.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "// 5. Validar tokenType\r",
              "pm.test(\"Login válido user 1 - tokenType debe ser Bearer\", function () {\r",
              "    pm.expect(responseJson.tokenType).to.eql(\"Bearer\");\r",
              "});\r",
              "\r",
              "// 6. Validar objeto user\r",
              "pm.test(\"Login válido user 1 - debe retornar el objeto user\", function () {\r",
              "    pm.expect(responseJson.user).to.exist;\r",
              "    pm.expect(responseJson.user).to.be.an(\"object\");\r",
              "});\r",
              "\r",
              "// 7. Validar email del usuario\r",
              "pm.test(\"Login válido user 1 - user.email debe coincidir con el email enviado\", function () {\r",
              "    pm.expect(responseJson.user.email).to.eql(pm.environment.get(\"valid_email_user_1\"));\r",
              "});\r",
              "\r",
              "// 8. Guardar variables del user 1 en environment\r",
              "pm.environment.set(\"access_token_user_1\", responseJson.accessToken);\r",
              "pm.environment.set(\"refresh_token_user_1\", responseJson.refreshToken);\r",
              "pm.environment.set(\"token_type_user_1\", responseJson.tokenType);\r",
              "pm.environment.set(\"user_id_user_1\", String(responseJson.user.id));\r",
              "pm.environment.set(\"user_email_user_1\", responseJson.user.email);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"email\": \"{{valid_email_user_1}}\",\r\n  \"password\": \"{{valid_password_user_1}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
