          "script": {
            "exec": [
              "const responseJson = pm.response.json();\r",
              "\r",
              "// 1. Validar status code\r",
              "pm.test(\"Login con credenciales inválidas - el status code debe ser 401\", function () {\r",
              "    pm.response.to.have.status(401);\r",
              "});\r",
              "\r",
              "// 2. Validar que la respuesta sea JSON\r",
              "pm.test(\"Login con credenciales inválidas - la respuesta debe ser JSON\", function () {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "});\r",
              "\r",
              "// 3. Validar status en el body\r",
              "pm.test(\"Login con credenciales inválidas - status del body debe ser 401\", function () {\r",
              "    pm.expect(responseJson.status).to.eql(401);\r",
              "});\r",
              "\r",
              "// 4. Validar tipo de error HTTP\r",
              "pm.test(\"Login con credenciales inválidas - error debe ser Unauthorized\", function () {\r",
              "    pm.expect(responseJson.error).to.eql(\"Unauthorized\");\r",
              "});\r",
              "\r",
              "// 5. Validar código interno del error\r",
              "pm.test(\"Login con credenciales inválidas - code debe ser CREDENCIALES_INVALIDAS\", function () {\r",
              "    pm.expect(responseJson.code).to.eql(\"CREDENCIALES_INVALIDAS\");\r",
              "});\r",
              "\r",
              "// 6. Validar mensaje de error\r",
              "pm.test(\"Login con credenciales inválidas - debe retornar mensaje de credenciales inválidas\", function () {\r",
              "    pm.expect(responseJson.message).to.eql(\"Credenciales inválidas.\");\r",
              "});\r",
              "\r",
              "// 7. Validar path del endpoint\r",
              "pm.test(\"Login con credenciales inválidas - path debe ser /api/auth/login\", function () {\r",
              "    pm.expect(responseJson.path).to.eql(\"/api/auth/login\");\r",
              "});\r",
              "\r",
              "// 8. Validar que no retorne tokens\r",
              "pm.test(\"Login con credenciales inválidas - no debe retornar accessToken ni refreshToken\", function () {\r",
              "    pm.expect(responseJson.accessToken).to.be.undefined;\r",
              "    pm.expect(responseJson.refreshToken).to.be.undefined;\r",
              "});\r",
              "\r",
              "// 9. Limpiar variables de autenticación para evitar contaminación\r",
              "pm.collectionVariables.unset(\"access_token\");\r",
              "pm.collectionVariables.unset(\"refresh_token\");\r",
              "pm.collectionVariables.unset(\"token_type\");\r",
              "pm.collectionVariables.unset(\"user_id\");\r",
              "pm.collectionVariables.unset(\"user_email\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
