              "    pm.expect(responseJson.funcionId).to.eql(funcionIdEsperada);\r",
              "});\r",
              "\r",
              "// 5. Validar que venga el arreglo de bloqueados\r",
              "pm.test(\"Bloquear asientos - debe retornar la lista de asientos bloqueados\", function () {\r",
              "    pm.expect(responseJson.bloqueados).to.exist;\r",
              "    pm.expect(responseJson.bloqueados).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "// 6. Validar que se hayan bloqueado exactamente 2 asientos\r",
              "pm.test(\"Bloquear asientos - debe bloquear exactamente 2 asientos\", function () {\r",
              "    pm.expect(responseJson.bloqueados.length).to.eql(2);\r",
              "});\r",
              "\r",
              "// 7. Validar que los asientos bloqueados sean los solicitados\r",
              "pm.test(\"Bloquear asientos - los asientos bloqueados deben coincidir con los solicitados\", function () {\r",
              "    pm.expect(responseJson.bloqueados).to.include(asiento1);\r",
              "    pm.expect(responseJson.bloqueados).to.include(asiento2);\r",
              "});\r",
              "\r",
              "// 8. Validar expiración de retención\r",
              "pm.test(\"Bloquear asientos - debe retornar expiraEn\", function () {\r",
              "    pm.expect(responseJson.expiraEn).to.exist;\r",
              "    pm.expect(responseJson.expiraEn).to.be.a(\"string\");\r",
              "    pm.expect(responseJson.expiraEn.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "// 9. Validar tiempo de respuesta\r",
              "pm.test(\"Bloquear asientos - tiempo de respuesta menor a 5000 ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(5000);\r",
              "});\r",
              "\r",
              "// 10. Guardar información útil para pruebas posteriores\r",
