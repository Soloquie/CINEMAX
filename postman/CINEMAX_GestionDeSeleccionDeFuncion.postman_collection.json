    {
      "name": "Consultar carrito",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let responseJson = {};\r",
              "try {\r",
              "    responseJson = pm.response.json();\r",
              "} catch (e) {\r",
              "    responseJson = {};\r",
              "}\r",
              "\r",
              "// 1. Validar status code\r",
              "pm.test(\"Consultar carrito - el status code debe ser 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// 2. Validar que la respuesta sea JSON\r",
              "pm.test(\"Consultar carrito - la respuesta debe ser JSON\", function () {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "});\r",
              "\r",
              "// 3. Validar estructura principal del carrito\r",
              "pm.test(\"Consultar carrito - debe retornar la estructura principal del carrito\", function () {\r",
              "    pm.expect(responseJson).to.have.property(\"carritoId\");\r",
              "    pm.expect(responseJson).to.have.property(\"estado\");\r",
              "    pm.expect(responseJson).to.have.property(\"expiraEn\");\r",
              "    pm.expect(responseJson).to.have.property(\"items\");\r",
              "});\r",
              "\r",
              "// 4. Validar tipos de datos principales\r",
              "pm.test(\"Consultar carrito - los campos principales deben tener tipos válidos\", function () {\r",
              "    pm.expect(responseJson.carritoId).to.be.a(\"number\");\r",
              "    pm.expect(responseJson.estado).to.be.a(\"string\");\r",
              "    pm.expect(responseJson.items).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "// 5. Validar que el estado del carrito no venga vacío\r",
              "pm.test(\"Consultar carrito - el estado del carrito no debe venir vacío\", function () {\r",
              "    pm.expect(responseJson.estado.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "// 6. Validar estructura del primer item solo si hay items\r",
              "pm.test(\"Consultar carrito - si hay items, el primero debe tener campos clave\", function () {\r",
              "    if (responseJson.items.length > 0) {\r",
              "        const item = responseJson.items[0];\r",
              "        pm.expect(item).to.have.property(\"itemId\");\r",
              "        pm.expect(item).to.have.property(\"tipo\");\r",
              "        pm.expect(item).to.have.property(\"cantidad\");\r",
              "        pm.expect(item).to.have.property(\"precioUnitario\");\r",
              "        pm.expect(item).to.have.property(\"subtotal\");\r",
              "    } else {\r",
              "        pm.expect(responseJson.items.length).to.eql(0);\r",
              "    }\r",
              "});\r",
              "\r",
              "// 7. Validar tipos del primer item solo si hay items\r",
              "pm.test(\"Consultar carrito - si hay items, sus campos principales deben tener tipos válidos\", function () {\r",
              "    if (responseJson.items.length > 0) {\r",
              "        const item = responseJson.items[0];\r",
              "        pm.expect(item.itemId).to.be.a(\"number\");\r",
              "        pm.expect(item.tipo).to.be.a(\"string\");\r",
              "        pm.expect(item.cantidad).to.be.a(\"number\");\r",
              "        pm.expect(item.precioUnitario).to.be.a(\"number\");\r",
              "        pm.expect(item.subtotal).to.be.a(\"number\");\r",
              "    } else {\r",
              "        pm.expect(true).to.eql(true);\r",
              "    }\r",
              "});\r",
              "\r",
              "// 8. Validar que cada item tenga cantidad válida\r",
              "pm.test(\"Consultar carrito - si hay items, cada uno debe tener cantidad mayor a 0\", function () {\r",
              "    responseJson.items.forEach(item => {\r",
              "        pm.expect(item.cantidad).to.be.above(0);\r",
              "    });\r",
              "});\r",
              "\r",
              "// 9. Validar tiempo de respuesta\r",
              "pm.test(\"Consultar carrito - tiempo de respuesta menor a 5000 ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(5000);\r",
              "});"
