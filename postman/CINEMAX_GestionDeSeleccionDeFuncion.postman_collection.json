              "// 3. Validar que venga funcionId\r",
              "pm.test(\"Bloquear asientos - debe retornar funcionId\", function () {\r",
              "    pm.expect(responseJson.funcionId).to.exist;\r",
              "    pm.expect(responseJson.funcionId).to.be.a(\"number\");\r",
              "});\r",
              "\r",
              "// 4. Validar que funcionId coincida con la función consultada\r",
