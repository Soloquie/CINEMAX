              "pm.collectionVariables.set(\"last_hold_asiento_1\", String(asiento1));\r",
              "pm.collectionVariables.set(\"last_hold_asiento_2\", String(asiento2));\r",
              "pm.collectionVariables.set(\"last_hold_expira_en\", responseJson.expiraEn);"
