  "item": [
    {
      "name": "Obtener funciones de una pelicula",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let responseJson = [];\r",
              "try {\r",
              "    responseJson = pm.response.json();\r",
              "} catch (e) {\r",
              "    responseJson = [];\r",
              "}\r",
              "\r",
              "// 1. Validar status code\r",
              "pm.test(\"Obtener funciones de una película - el status code debe ser 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// 2. Validar que la respuesta sea JSON\r",
              "pm.test(\"Obtener funciones de una película - la respuesta debe ser JSON\", function () {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "});\r",
              "\r",
              "// 3. Validar que la respuesta sea un arreglo\r",
              "pm.test(\"Obtener funciones de una película - la respuesta debe ser un arreglo\", function () {\r",
              "    pm.expect(responseJson).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "// 4. Validar que el arreglo no esté vacío\r",
              "pm.test(\"Obtener funciones de una película - debe retornar al menos una función\", function () {\r",
              "    pm.expect(responseJson.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "// 5. Validar estructura básica del primer elemento\r",
              "pm.test(\"Obtener funciones de una película - la primera función debe tener campos clave\", function () {\r",
              "    const funcion = responseJson[0];\r",
              "    pm.expect(funcion).to.have.property(\"id\");\r",
              "    pm.expect(funcion).to.have.property(\"peliculaId\");\r",
              "    pm.expect(funcion).to.have.property(\"salaId\");\r",
              "    pm.expect(funcion).to.have.property(\"cineId\");\r",
              "    pm.expect(funcion).to.have.property(\"inicio\");\r",
              "    pm.expect(funcion).to.have.property(\"fin\");\r",
              "    pm.expect(funcion).to.have.property(\"precioBase\");\r",
              "    pm.expect(funcion).to.have.property(\"estado\");\r",
              "});\r",
              "\r",
              "// 6. Validar que la película corresponda a la solicitada\r",
              "pm.test(\"Obtener funciones de una película - peliculaId debe coincidir con la solicitada\", function () {\r",
              "    const peliculaIdEsperada = Number(pm.environment.get(\"pelicula_id_valida\"));\r",
              "    responseJson.forEach(funcion => {\r",
              "        pm.expect(funcion.peliculaId).to.eql(peliculaIdEsperada);\r",
              "    });\r",
              "});\r",
              "\r",
              "// 7. Validar tipos de datos importantes\r",
              "pm.test(\"Obtener funciones de una película - campos clave deben tener tipos válidos\", function () {\r",
              "    const funcion = responseJson[0];\r",
              "    pm.expect(funcion.id).to.be.a(\"number\");\r",
              "    pm.expect(funcion.peliculaId).to.be.a(\"number\");\r",
              "    pm.expect(funcion.salaId).to.be.a(\"number\");\r",
              "    pm.expect(funcion.cineId).to.be.a(\"number\");\r",
              "    pm.expect(funcion.precioBase).to.be.a(\"number\");\r",
              "    pm.expect(funcion.estado).to.be.a(\"string\");\r",
              "});\r",
              "\r",
              "// 8. Validar tiempo de respuesta\r",
              "pm.test(\"Obtener funciones de una película - tiempo de respuesta menor a 5000 ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(5000);\r",
              "});\r",
              "\r",
              "// 9. Guardar datos para requests siguientes\r",
              "pm.collectionVariables.set(\"selected_funcion_id\", String(responseJson[0].id));\r",
              "pm.collectionVariables.set(\"selected_pelicula_id\", String(responseJson[0].peliculaId));\r",
              "pm.collectionVariables.set(\"selected_cine_id\", String(responseJson[0].cineId));\r",
              "pm.collectionVariables.set(\"selected_sala_id\", String(responseJson[0].salaId));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
