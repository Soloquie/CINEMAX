  "item": [
    {
      "name": "Mostrar productos",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let responseJson = [];\r",
              "try {\r",
              "    responseJson = pm.response.json();\r",
              "} catch (e) {\r",
              "    responseJson = [];\r",
              "}\r",
              "\r",
              "// 1. Validar status code\r",
              "pm.test(\"Mostrar productos - el status code debe ser 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// 2. Validar que la respuesta sea JSON\r",
              "pm.test(\"Mostrar productos - la respuesta debe ser JSON\", function () {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "});\r",
              "\r",
              "// 3. Validar que la respuesta sea un arreglo\r",
              "pm.test(\"Mostrar productos - la respuesta debe ser un arreglo\", function () {\r",
              "    pm.expect(responseJson).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "// 4. Validar que el arreglo no esté vacío\r",
              "pm.test(\"Mostrar productos - debe retornar al menos un producto\", function () {\r",
              "    pm.expect(responseJson.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "// 5. Validar estructura del primer producto\r",
              "pm.test(\"Mostrar productos - el primer producto debe tener campos clave\", function () {\r",
              "    const producto = responseJson[0];\r",
              "    pm.expect(producto).to.have.property(\"id\");\r",
              "    pm.expect(producto).to.have.property(\"sku\");\r",
              "    pm.expect(producto).to.have.property(\"nombre\");\r",
              "    pm.expect(producto).to.have.property(\"descripcion\");\r",
              "    pm.expect(producto).to.have.property(\"precio\");\r",
              "    pm.expect(producto).to.have.property(\"categoria\");\r",
              "    pm.expect(producto).to.have.property(\"imagenUrl\");\r",
              "    pm.expect(producto).to.have.property(\"activo\");\r",
              "    pm.expect(producto).to.have.property(\"stock\");\r",
              "});\r",
              "\r",
              "// 6. Validar tipos de datos del primer producto\r",
              "pm.test(\"Mostrar productos - los campos del primer producto deben tener tipos válidos\", function () {\r",
              "    const producto = responseJson[0];\r",
              "    pm.expect(producto.id).to.be.a(\"number\");\r",
              "    pm.expect(producto.sku).to.be.a(\"string\");\r",
              "    pm.expect(producto.nombre).to.be.a(\"string\");\r",
              "    pm.expect(producto.descripcion).to.be.a(\"string\");\r",
              "    pm.expect(producto.precio).to.be.a(\"number\");\r",
              "    pm.expect(producto.categoria).to.be.a(\"string\");\r",
              "    pm.expect(producto.imagenUrl).to.be.a(\"string\");\r",
              "    pm.expect(producto.activo).to.be.a(\"boolean\");\r",
              "    pm.expect(producto.stock).to.be.a(\"number\");\r",
              "});\r",
              "\r",
              "// 7. Validar que todos los productos tengan nombre y categoría\r",
              "pm.test(\"Mostrar productos - todos los productos deben tener nombre y categoría\", function () {\r",
              "    responseJson.forEach(producto => {\r",
              "        pm.expect(producto.nombre).to.exist;\r",
              "        pm.expect(producto.nombre).to.be.a(\"string\");\r",
              "        pm.expect(producto.nombre.length).to.be.above(0);\r",
              "\r",
              "        pm.expect(producto.categoria).to.exist;\r",
              "        pm.expect(producto.categoria).to.be.a(\"string\");\r",
              "        pm.expect(producto.categoria.length).to.be.above(0);\r",
              "    });\r",
              "});\r",
              "\r",
              "// 8. Validar tiempo de respuesta\r",
              "pm.test(\"Mostrar productos - tiempo de respuesta menor a 5000 ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(5000);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{access_token_user_1}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
