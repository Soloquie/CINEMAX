              "}\r",
              "\r",
              "pm.test(\"Consultar estado válido - status code debe ser 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Consultar estado válido - la respuesta debe ser JSON\", function () {\r",
