    {
      "name": "Consultar estado con referencia inexistente",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let responseJson = {};\r",
              "try {\r",
              "    responseJson = pm.response.json();\r",
              "} catch (e) {\r",
              "    responseJson = {};\r",
              "}\r",
              "\r",
              "// 1. Validar status code\r",
              "pm.test(\"Consultar estado con referencia inexistente - el status code debe ser 404\", function () {\r",
              "    pm.response.to.have.status(404);\r",
              "});\r",
              "\r",
              "// 2. Validar que la respuesta sea JSON\r",
              "pm.test(\"Consultar estado con referencia inexistente - la respuesta debe ser JSON\", function () {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "});\r",
              "\r",
              "// 3. Validar status del body\r",
              "pm.test(\"Consultar estado con referencia inexistente - status del body debe ser 404\", function () {\r",
              "    pm.expect(responseJson.status).to.eql(404);\r",
              "});\r",
              "\r",
              "// 4. Validar tipo de error HTTP\r",
              "pm.test(\"Consultar estado con referencia inexistente - error debe ser Not Found\", function () {\r",
              "    pm.expect(responseJson.error).to.eql(\"Not Found\");\r",
              "});\r",
              "\r",
              "// 5. Validar código interno\r",
              "pm.test(\"Consultar estado con referencia inexistente - code debe ser PAGO_NO_ENCONTRADO\", function () {\r",
              "    pm.expect(responseJson.code).to.eql(\"PAGO_NO_ENCONTRADO\");\r",
              "});\r",
              "\r",
              "// 6. Validar mensaje\r",
              "pm.test(\"Consultar estado con referencia inexistente - debe retornar el mensaje esperado\", function () {\r",
              "    pm.expect(responseJson.message).to.eql(\"El pago no existe.\");\r",
              "});\r",
              "\r",
              "// 7. Validar path\r",
              "pm.test(\"Consultar estado con referencia inexistente - path debe corresponder al endpoint de estado\", function () {\r",
              "    pm.expect(responseJson.path).to.include(\"/api/pagos/estado/\");\r",
              "});\r",
              "\r",
              "// 8. Validar que no retorne datos del DTO de pago exitoso\r",
              "pm.test(\"Consultar estado con referencia inexistente - no debe retornar datos de estado de pago\", function () {\r",
              "    pm.expect(responseJson.referencia).to.be.undefined;\r",
              "    pm.expect(responseJson.estadoPago).to.be.undefined;\r",
              "    pm.expect(responseJson.estadoVenta).to.be.undefined;\r",
              "    pm.expect(responseJson.ventaId).to.be.undefined;\r",
              "    pm.expect(responseJson.codigoVenta).to.be.undefined;\r",
              "});\r",
              "\r",
              "// 9. Validar tiempo de respuesta\r",
              "pm.test(\"Consultar estado con referencia inexistente - tiempo de respuesta menor a 5000 ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(5000);\r",
              "});"
