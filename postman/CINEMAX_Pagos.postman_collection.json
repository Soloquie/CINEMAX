              "});\r",
              "\r",
              "pm.test(\"Consultar estado válido - debe incluir campos del DTO\", function () {\r",
              "    pm.expect(responseJson).to.have.property(\"estadoVenta\");\r",
              "    pm.expect(responseJson).to.have.property(\"ventaId\");\r",
              "    pm.expect(responseJson).to.have.property(\"codigoVenta\");\r",
              "    pm.expect(responseJson).to.have.property(\"mensaje\");\r",
              "});\r",
              "\r",
              "pm.test(\"Consultar estado válido - tiempo de respuesta menor a 5000 ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(5000);\r",
              "});"
            ],
