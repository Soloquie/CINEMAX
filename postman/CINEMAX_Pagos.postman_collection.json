  "item": [
    {
      "name": "Crear checkout válido Stripe",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let responseJson = {};\r",
              "try {\r",
              "    responseJson = pm.response.json();\r",
              "} catch (e) {\r",
              "    responseJson = {};\r",
              "}\r",
              "\r",
              "pm.test(\"Checkout Stripe - status code 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Checkout Stripe - respuesta JSON\", function () {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "});\r",
              "\r",
              "pm.test(\"Checkout Stripe - debe retornar campos principales\", function () {\r",
              "    pm.expect(responseJson.referencia).to.exist;\r",
              "    pm.expect(responseJson.proveedor).to.eql(\"STRIPE\");\r",
              "    pm.expect(responseJson.montoCentavos).to.be.a(\"number\");\r",
              "    pm.expect(responseJson.moneda).to.be.a(\"string\");\r",
              "    pm.expect(responseJson.checkoutId).to.exist;\r",
              "    pm.expect(responseJson.initPoint).to.exist;\r",
              "    pm.expect(responseJson.publicKey).to.exist;\r",
              "});\r",
              "\r",
              "pm.test(\"Checkout Stripe - montoCentavos debe ser mayor que 0\", function () {\r",
              "    pm.expect(responseJson.montoCentavos).to.be.above(0);\r",
              "});\r",
              "\r",
              "pm.collectionVariables.set(\"checkout_referencia\", responseJson.referencia);\r",
              "pm.collectionVariables.set(\"checkout_proveedor\", responseJson.proveedor);\r",
              "pm.collectionVariables.set(\"checkout_checkoutId\", responseJson.checkoutId);\r",
              "pm.collectionVariables.set(\"checkout_initPoint\", responseJson.initPoint);\r",
              "pm.collectionVariables.set(\"checkout_publicKey\", responseJson.publicKey);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{access_token_user_1}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"proveedor\": \"{{pago_proveedor_stripe}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/pagos/checkout",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "pagos",
            "checkout"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Crear checkout con proveedor invalido",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let responseJson = {};\r",
              "try {\r",
              "    responseJson = pm.response.json();\r",
              "} catch (e) {\r",
              "    responseJson = {};\r",
              "}\r",
              "\r",
              "// 1. Validar status code\r",
              "pm.test(\"Checkout con proveedor inválido - el status code debe ser 409\", function () {\r",
              "    pm.response.to.have.status(409);\r",
              "});\r",
              "\r",
              "// 2. Validar que la respuesta sea JSON\r",
              "pm.test(\"Checkout con proveedor inválido - la respuesta debe ser JSON\", function () {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "});\r",
              "\r",
              "// 3. Validar status del body\r",
              "pm.test(\"Checkout con proveedor inválido - status del body debe ser 409\", function () {\r",
              "    pm.expect(responseJson.status).to.eql(409);\r",
              "});\r",
              "\r",
              "// 4. Validar tipo de error HTTP\r",
              "pm.test(\"Checkout con proveedor inválido - error debe ser Conflict\", function () {\r",
              "    pm.expect(responseJson.error).to.eql(\"Conflict\");\r",
              "});\r",
              "\r",
              "// 5. Validar código interno\r",
              "pm.test(\"Checkout con proveedor inválido - code debe ser PAGO_INVALIDO\", function () {\r",
              "    pm.expect(responseJson.code).to.eql(\"PAGO_INVALIDO\");\r",
              "});\r",
              "\r",
              "// 6. Validar mensaje exacto\r",
              "pm.test(\"Checkout con proveedor inválido - debe retornar el mensaje esperado\", function () {\r",
              "    pm.expect(responseJson.message).to.eql(\"Proveedor de pago no soportado: PAYPAL\");\r",
              "});\r",
              "\r",
              "// 7. Validar path\r",
              "pm.test(\"Checkout con proveedor inválido - path debe ser /api/pagos/checkout\", function () {\r",
              "    pm.expect(responseJson.path).to.eql(\"/api/pagos/checkout\");\r",
              "});\r",
              "\r",
              "// 8. Validar que no retorne datos de checkout\r",
              "pm.test(\"Checkout con proveedor inválido - no debe retornar referencia ni checkoutId\", function () {\r",
              "    pm.expect(responseJson.referencia).to.be.undefined;\r",
              "    pm.expect(responseJson.checkoutId).to.be.undefined;\r",
              "    pm.expect(responseJson.initPoint).to.be.undefined;\r",
              "});\r",
              "\r",
              "// 9. Validar tiempo de respuesta\r",
              "pm.test(\"Checkout con proveedor inválido - tiempo de respuesta menor a 5000 ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(5000);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{access_token_user_1}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"proveedor\": \"{{pago_proveedor_invalido}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/pagos/checkout",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "pagos",
            "checkout"
          ]
        }
      },
      "response": []
    },
